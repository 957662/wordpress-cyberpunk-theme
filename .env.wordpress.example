# WordPress API 配置
# 复制此文件到 .env.local 并填入实际值

# WordPress REST API 基础 URL
# 示例: https://your-wordpress-site.com/wp-json
NEXT_PUBLIC_WORDPRESS_API_URL=

# WordPress API 密钥（如果需要）
# 可选，仅当 WordPress 端需要认证时使用
NEXT_PUBLIC_WORDPRESS_API_KEY=

# JWT 认证 URL（如果使用 JWT 插件）
# 示例: https://your-wordpress-site.com/wp-json/jwt-auth/v1
NEXT_PUBLIC_JWT_AUTH_URL=

# WordPress 站点 URL（用于生成链接）
# 示例: https://your-wordpress-site.com
NEXT_PUBLIC_WORDPRESS_SITE_URL=

# API 请求超时时间（毫秒）
NEXT_PUBLIC_WORDPRESS_API_TIMEOUT=10000

# 启用详细日志（开发模式）
NEXT_PUBLIC_WORDPRESS_DEBUG=true

# 默认每页显示数量
NEXT_PUBLIC_WORDPRESS_POSTS_PER_PAGE=10

# 默认排序方式
# 可选值: date, title, slug, modified
NEXT_PUBLIC_WORDPRESS_ORDER_BY=date

# 默认排序方向
# 可选值: asc, desc
NEXT_PUBLIC_WORDPRESS_ORDER=desc
