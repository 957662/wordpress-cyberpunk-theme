# CyberPress Platform - 前端生产环境配置模板
# 复制此文件为 .env.production 并填写正确的值

###############################################################################
# 应用配置
###############################################################################
NEXT_PUBLIC_APP_NAME=CyberPress Platform
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_DESCRIPTION=赛博朋克风格博客平台

###############################################################################
# API 配置
###############################################################################
# 后端 API 地址
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com
NEXT_PUBLIC_API_V1_PREFIX=/api/v1

# WebSocket 地址
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws

###############################################################################
# 功能开关
###############################################################################
# 用户功能
NEXT_PUBLIC_FEATURE_AUTH=true
NEXT_PUBLIC_FEATURE_REGISTRATION=true
NEXT_PUBLIC_FEATURE_SOCIAL_LOGIN=true

# 内容功能
NEXT_PUBLIC_FEATURE_BLOG=true
NEXT_PUBLIC_FEATURE_PORTFOLIO=true
NEXT_PUBLIC_FEATURE_COMMENTS=true

# 社交功能
NEXT_PUBLIC_FEATURE_FOLLOW=true
NEXT_PUBLIC_FEATURE_LIKE=true
NEXT_PUBLIC_FEATURE_BOOKMARK=true

# 实时功能
NEXT_PUBLIC_FEATURE_WEBSOCKET=true
NEXT_PUBLIC_FEATURE_NOTIFICATIONS=true
NEXT_PUBLIC_FEATURE_MESSAGES=true

# 其他功能
NEXT_PUBLIC_FEATURE_SEARCH=true
NEXT_PUBLIC_FEATURE_ANALYTICS=true
NEXT_PUBLIC_FEATURE_NEWSLETTER=true

###############################################################################
# OAuth2 配置
###############################################################################
# GitHub OAuth
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
NEXT_PUBLIC_GITHUB_OAUTH_REDIRECT_URI=https://yourdomain.com/auth/github/callback

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=https://yourdomain.com/auth/google/callback

###############################################################################
# 第三方服务
###############################################################################
# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=your_google_analytics_id

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=your_google_adsense_client_id

# Sentry 错误追踪
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Disqus 评论
NEXT_PUBLIC_DISQUS_SHORTNAME=your_disqus_shortname

###############################################################################
# 性能和监控
###############################################################################
# 性能监控
NEXT_PUBLIC_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_PERFORMANCE_SAMPLE_RATE=0.1

# 错误追踪
NEXT_PUBLIC_ERROR_TRACKING=true

# 分析
NEXT_PUBLIC_ANALYTICS_ENABLED=true

###############################################################################
# 内容配置
###############################################################################
# 博客配置
NEXT_PUBLIC_BLOG_POSTS_PER_PAGE=12
NEXT_PUBLIC_BLOG_RELATED_POSTS_COUNT=4
NEXT_PUBLIC_BLOG_LATEST_POSTS_COUNT=5

# 评论配置
NEXT_PUBLIC_COMMENTS_PER_PAGE=20
NEXT_PUBLIC_COMMENT_MAX_LENGTH=5000

# 搜索配置
NEXT_PUBLIC_SEARCH_RESULTS_PER_PAGE=20
NEXT_PUBLIC_SEARCH_MIN_LENGTH=2

###############################################################################
# UI 配置
###############################################################################
# 分页
NEXT_PUBLIC_PAGINATION_ITEMS_PER_PAGE=12
NEXT_PUBLIC_PAGINATION_PAGE_RANGE=3

# 图片
NEXT_PUBLIC_IMAGE_QUALITY=85
NEXT_PUBLIC_IMAGE_FORMATS=avif,webp,jpg

# 动画
NEXT_PUBLIC_ANIMATION_DURATION=300
NEXT_PUBLIC_ANIMATION_EASING=ease-in-out

# 主题
NEXT_PUBLIC_DEFAULT_THEME=dark
NEXT_PUBLIC_THEME_STORAGE_KEY=cyberpress-theme

###############################################################################
# 缓存配置
###############################################################################
# 浏览器缓存
NEXT_PUBLIC_CACHE_ENABLED=true
NEXT_PUBLIC_CACHE_TIME=300000

# 数据缓存
NEXT_PUBLIC_DATA_CACHE_TIME=60000
NEXT_PUBLIC_STATIC_CACHE_TIME=3600000

###############################################################################
# 安全配置
###############################################################################
# CSP
NEXT_PUBLIC_CSP_ENABLED=true

# HTTPS 强制
NEXT_PUBLIC_FORCE_HTTPS=true

###############################################################################
# 限流配置
###############################################################################
# API 请求限流
NEXT_PUBLIC_API_RATE_LIMIT=100
NEXT_PUBLIC_API_RATE_INTERVAL=60000

# 上传限流
NEXT_PUBLIC_UPLOAD_RATE_LIMIT=5
NEXT_PUBLIC_UPLOAD_RATE_INTERVAL=60000

###############################################################################
# 国际化配置
###############################################################################
# 默认语言
NEXT_PUBLIC_DEFAULT_LOCALE=zh
NEXT_PUBLIC_LOCALES=zh,en,ja,ko

# 时区
NEXT_PUBLIC_TIMEZONE=Asia/Shanghai

# 日期格式
NEXT_PUBLIC_DATE_FORMAT=YYYY-MM-DD
NEXT_PUBLIC_TIME_FORMAT=HH:mm:ss
NEXT_PUBLIC_DATETIME_FORMAT=YYYY-MM-DD HH:mm:ss

###############################################################################
# SEO 配置
###############################################################################
# 网站元信息
NEXT_PUBLIC_SITE_TITLE=CyberPress Platform
NEXT_PUBLIC_SITE_DESCRIPTION=赛博朋克风格博客平台，基于 Next.js 和 FastAPI 构建
NEXT_PUBLIC_SITE_KEYWORDS=blog,cyberpunk,next.js,fastapi,typescript

# 作者信息
NEXT_PUBLIC_AUTHOR_NAME=Your Name
NEXT_PUBLIC_AUTHOR_EMAIL=your.email@yourdomain.com
NEXT_PUBLIC_AUTHOR_URL=https://yourdomain.com

# Open Graph
NEXT_PUBLIC_OG_IMAGE=https://yourdomain.com/og-image.jpg
NEXT_PUBLIC_OG_TYPE=website

# Twitter Card
NEXT_PUBLIC_TWITTER_CARD=summary_large_image
NEXT_PUBLIC_TWITTER_SITE=@yourusername
NEXT_PUBLIC_TWITTER_CREATOR=@yourusername

###############################################################################
# 联系方式
###############################################################################
NEXT_PUBLIC_CONTACT_EMAIL=contact@yourdomain.com
NEXT_PUBLIC_CONTACT_TELEGRAM=https://t.me/yourusername
NEXT_PUBLIC_CONTACT_GITHUB=https://github.com/yourusername
NEXT_PUBLIC_CONTACT_TWITTER=https://twitter.com/yourusername

###############################################################################
# 社交链接
###############################################################################
NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/yourusername
NEXT_PUBLIC_SOCIAL_TWITTER=https://twitter.com/yourusername
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/in/yourusername
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@yourusername

###############################################################################
# 存储配置
###############################################################################
# CDN
NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com

# 文件上传
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

###############################################################################
# WebSocket 配置
###############################################################################
# 连接
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=3000
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=10
NEXT_PUBLIC_WS_HEARTBEAT_INTERVAL=30000

# 消息队列
NEXT_PUBLIC_WS_MESSAGE_QUEUE_ENABLED=true
NEXT_PUBLIC_WS_MESSAGE_QUEUE_SIZE=100

###############################################################################
# 通知配置
###############################################################################
# 桌面通知
NEXT_PUBLIC_NOTIFICATION_ENABLED=true
NEXT_PUBLIC_NOTIFICATION_PERMISSION=default

# 声音通知
NEXT_PUBLIC_SOUND_NOTIFICATIONS=true

###############################################################################
# 广告配置
###############################################################################
# Google AdSense
NEXT_PUBLIC_ADSENSE_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# 其他广告
NEXT_PUBLIC_AD_FOOTER_ENABLED=false
NEXT_PUBLIC_AD_SIDEBAR_ENABLED=false

###############################################################################
# 隐私和合规
###############################################################################
# Cookie 同意
NEXT_PUBLIC_COOKIE_CONSENT_ENABLED=true

# GDPR
NEXT_PUBLIC_GDPR_ENABLED=true

# 隐私政策
NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy
NEXT_PUBLIC_TERMS_OF_SERVICE_URL=/terms

###############################################################################
# 开发工具（生产环境禁用）
###############################################################################
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_DEVTOOLS=false
NEXT_PUBLIC_LOGGER=false
