# ========================================
# CyberPress Platform - 完整环境配置示例
# ========================================
# 复制此文件为 .env.local 并填写实际值

# ========================================
# 基础配置
# ========================================
NEXT_PUBLIC_SITE_NAME=CyberPress
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DOMAIN=localhost:3000

# ========================================
# API 配置
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3
NEXT_PUBLIC_API_RETRY_DELAY=1000

# ========================================
# 功能开关
# ========================================
# 博客功能
NEXT_PUBLIC_FEATURE_BLOG=true
NEXT_PUBLIC_FEATURE_COMMENTS=true
NEXT_PUBLIC_FEATURE_SEARCH=true
NEXT_PUBLIC_FEATURE_TAGS=true
NEXT_PUBLIC_FEATURE_CATEGORIES=true
NEXT_PUBLIC_FEATURE_RSS=true

# 用户功能
NEXT_PUBLIC_FEATURE_AUTH=true
NEXT_PUBLIC_FEATURE_REGISTRATION=true
NEXT_PUBLIC_FEATURE_PASSWORD_RESET=true
NEXT_PUBLIC_FEATURE_PROFILE=true

# 社交功能
NEXT_PUBLIC_FEATURE_FOLLOW=true
NEXT_PUBLIC_FEATURE_LIKE=true
NEXT_PUBLIC_FEATURE_BOOKMARK=true
NEXT_PUBLIC_FEATURE_SHARE=true

# 通知功能
NEXT_PUBLIC_FEATURE_NOTIFICATIONS=true
NEXT_PUBLIC_FEATURE_PUSH_NOTIFICATIONS=false
NEXT_PUBLIC_FEATURE_EMAIL_NOTIFICATIONS=false

# 其他功能
NEXT_PUBLIC_FEATURE_NEWSLETTER=true
NEXT_PUBLIC_FEATURE_ANALYTICS=false
NEXT_PUBLIC_PWA_ENABLED=true

# ========================================
# 分析和监控
# ========================================
# Google Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=

# 其他分析工具
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_UMAMI_ID=

# 错误追踪
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# ========================================
# 认证配置
# ========================================
NEXT_PUBLIC_AUTH_PROVIDERS=local,google,github
NEXT_PUBLIC_AUTH_TOKEN_REFRESH_INTERVAL=300000
NEXT_PUBLIC_AUTH_SESSION_TIMEOUT=3600000

# OAuth 配置
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# ========================================
# 搜索配置
# ========================================
NEXT_PUBLIC_SEARCH_PROVIDER=algolia
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_ONLY_API_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=posts

# ========================================
# 评论系统配置
# ========================================
NEXT_PUBLIC_COMMENT_SYSTEM=native
NEXT_PUBLIC_COMMENT_MODERATION=true
NEXT_PUBLIC_COMMENT_MAX_DEPTH=3
NEXT_PUBLIC_COMMENT_ALLOW_MARKDOWN=true
NEXT_PUBLIC_COMMENT_ALLOW_ANONYMOUS=false

# Disqus (可选)
NEXT_PUBLIC_DISQUS_SHORTNAME=

# ========================================
# Newsletter 配置
# ========================================
NEXT_PUBLIC_NEWSLETTER_PROVIDER=convertkit
NEXT_PUBLIC_CONVERTKIT_FORM_ID=
NEXT_PUBLIC_MAILCHIMP_ENDPOINT=

# ========================================
# 文件上传配置
# ========================================
NEXT_PUBLIC_UPLOAD_MAX_SIZE=5242880
NEXT_PUBLIC_UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp
NEXT_PUBLIC_AVATAR_MAX_SIZE=2097152

# ========================================
# 性能配置
# ========================================
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true
NEXT_PUBLIC_IMAGE_LOADING=lazy
NEXT_PUBLIC_CODE_SPLITTING=true
NEXT_PUBLIC_PREFETCH_LINKS=true

# ========================================
# 缓存配置
# ========================================
NEXT_PUBLIC_CACHE_ENABLED=true
NEXT_PUBLIC_CACHE_TTL=3600
NEXT_PUBLIC_CACHE_MAX_SIZE=100

# ========================================
# 国际化配置
# ========================================
NEXT_PUBLIC_I18N_ENABLED=false
NEXT_PUBLIC_I18N_DEFAULT_LOCALE=zh-CN
NEXT_PUBLIC_I18N_LOCALES=zh-CN,en-US

# ========================================
# 主题配置
# ========================================
NEXT_PUBLIC_THEME_MODE=dark
NEXT_PUBLIC_THEME_PRIMARY_COLOR=#00f0ff
NEXT_PUBLIC_THEME_ACCENT_COLOR=#9d00ff
NEXT_PUBLIC_THEME_FONT_SIZE=md
NEXT_PUBLIC_THEME_REDUCED_MOTION=false

# ========================================
# API 密钥 (后端使用)
# ========================================
# 这些变量不应该暴露在前端
# 仅在后端 .env 文件中使用

# Stripe (支付)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SendGrid (邮件)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# AWS S3 (文件存储)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Cloudinary (图片处理)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ========================================
# 第三方服务
# ========================================
# OpenAI (AI 功能)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Firebase (实时功能)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ========================================
# 开发工具
# ========================================
# Debug 模式
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_VERBOSE_LOGGING=false

# Mock 数据
NEXT_PUBLIC_USE_MOCK_DATA=false

# ========================================
# 部署配置
# ========================================
# Vercel
VERCEL_URL=
VERCEL_ENV=

# Docker
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=

# ========================================
# 安全配置
# ========================================
# CORS
NEXT_PUBLIC_CORS_ENABLED=true
NEXT_PUBLIC_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
NEXT_PUBLIC_RATE_LIMIT_ENABLED=true
NEXT_PUBLIC_RATE_LIMIT_MAX_REQUESTS=100
NEXT_PUBLIC_RATE_LIMIT_WINDOW=60000

# CSRF
NEXT_PUBLIC_CSRF_ENABLED=true

# ========================================
# 日志配置
# ========================================
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_LOG_TO_CONSOLE=true
NEXT_PUBLIC_LOG_TO_REMOTE=false

# ========================================
# 功能标志 (Feature Flags)
# ========================================
# Beta 功能
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# 实验性功能
NEXT_PUBLIC_ENABLE_EXPERIMENTAL=false

# 维护模式
NEXT_PUBLIC_MAINTENANCE_MODE=false

# ========================================
# 自定义配置
# ========================================
# 添加你的自定义配置项
# NEXT_PUBLIC_CUSTOM_KEY=value

# ========================================
# 说明
# ========================================
# 1. 带 NEXT_PUBLIC_ 前缀的变量会暴露在浏览器端
# 2. 不带前缀的变量仅用于服务器端
# 3. 敏感信息不要使用 NEXT_PUBLIC_ 前缀
# 4. 修改配置后需要重启开发服务器
# 5. 不要将 .env.local 文件提交到版本控制

# ========================================
# 快速开始
# ========================================
# 1. 复制此文件: cp .env.complete.example .env.local
# 2. 编辑 .env.local 填写实际值
# 3. 重启开发服务器: npm run dev
