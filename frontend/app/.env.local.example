# CyberPress Platform - 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# =====================================================
# WordPress API 配置
# =====================================================
# WordPress REST API 基础 URL
NEXT_PUBLIC_WP_API_URL=http://localhost:8080/wp-json

# WordPress 认证令牌（可选，用于受保护的内容）
# WP_AUTH_TOKEN=your_auth_token_here

# =====================================================
# 网站配置
# =====================================================
# 网站 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 网站名称
NEXT_PUBLIC_SITE_NAME=CyberPress

# 网站描述
NEXT_PUBLIC_SITE_DESCRIPTION=赛博朋克风格的博客平台

# =====================================================
# 分析和追踪
# =====================================================
# Google Analytics ID（可选）
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager ID（可选）
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXX

# =====================================================
# 社交媒体链接
# =====================================================
# GitHub URL
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername

# Twitter URL
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/yourusername

# LinkedIn URL
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourusername

# =====================================================
# 功能开关
# =====================================================
# 启用评论系统
NEXT_PUBLIC_FEATURE_COMMENTS=true

# 启用搜索功能
NEXT_PUBLIC_FEATURE_SEARCH=true

# 启用 RSS 订阅
NEXT_PUBLIC_FEATURE_RSS=true

# =====================================================
# API 配置
# =====================================================
# API 超时时间（毫秒）
NEXT_PUBLIC_API_TIMEOUT=10000

# 启用 API 缓存
NEXT_PUBLIC_API_CACHE_ENABLED=true

# API 缓存时间（毫秒）
NEXT_PUBLIC_API_CACHE_TIME=300000

# =====================================================
# 其他配置
# =====================================================
# 默认每页文章数
NEXT_PUBLIC_POSTS_PER_PAGE=10

# 默认语言
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# 时区
NEXT_PUBLIC_TIMEZONE=Asia/Shanghai
