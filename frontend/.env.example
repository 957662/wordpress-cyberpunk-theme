# 应用配置
NEXT_PUBLIC_APP_URL=https://cyberpress.com
NEXT_PUBLIC_APP_VERSION=1.0.0

# API 配置
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WORDPRESS_URL=https://your-wordpress-site.com

# 分析工具
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=cyberpress.com

# 功能开关
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ADS_ENABLED=false

# CDN 配置
NEXT_PUBLIC_CDN_ENABLED=false
NEXT_PUBLIC_CDN_URL=

# 社交媒体
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/yourusername
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourusername
NEXT_PUBLIC_EMAIL=contact@cyberpress.com

# AI 服务（可选）
NEXT_PUBLIC_AI_API_KEY=your_ai_api_key_here
NEXT_PUBLIC_AI_BASE_URL=https://api.openai.com/v1

# 数据库（仅供后端使用）
DATABASE_URL=mysql://user:password@localhost:3306/cyberpress

# 认证密钥（仅供后端使用）
JWT_SECRET=your_jwt_secret_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://cyberpress.com
