# ===================================================================
# CyberPress Platform - Environment Variables
# ===================================================================
# Copy this file to .env.local and fill in your values

# ===================================================================
# Site Configuration
# ===================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=CyberPress
NEXT_PUBLIC_SITE_DESCRIPTION=A next-generation blog platform

# ===================================================================
# WordPress API (Headless CMS)
# ===================================================================
NEXT_PUBLIC_WP_API_URL=https://your-wordpress-site.com/wp-json
NEXT_PUBLIC_WP_URL=https://your-wordpress-site.com

# ===================================================================
# Authentication
# ===================================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# ===================================================================
# Database (Optional - if using custom backend)
# ===================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/cyberpress
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ===================================================================
# Redis (Optional - for caching)
# ===================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===================================================================
# Analytics
# ===================================================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com
NEXT_PUBLIC_PLAUSIBLE_URL=https://plausible.io

# ===================================================================
# Feature Flags
# ===================================================================
NEXT_PUBLIC_FEATURE_COMMENTS=true
NEXT_PUBLIC_FEATURE_NEWSLETTER=true
NEXT_PUBLIC_FEATURE_SEARCH=true
NEXT_PUBLIC_FEATURE_PWA=true
NEXT_PUBLIC_FEATURE_ANALYTICS=true

# ===================================================================
# Email Service (for notifications)
# ===================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@cyberpress.dev

# SendGrid (alternative)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@cyberpress.dev

# ===================================================================
# File Upload (for media management)
# ===================================================================
# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cyberpress-media

# Cloudflare R2 (alternative)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=cyberpress-media

# ===================================================================
# Search Engine (for advanced search)
# ===================================================================
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=your-meilisearch-key

# Algolia (alternative)
ALGOLIA_APP_ID=your-app-id
ALGOLIA_SEARCH_KEY=your-search-key
ALGOLIA_ADMIN_KEY=your-admin-key

# ===================================================================
# Social Media (for sharing)
# ===================================================================
NEXT_PUBLIC_TWITTER_HANDLE=@cyberpress
NEXT_PUBLIC_GITHUB_URL=https://github.com/cyberpress-platform

# ===================================================================
# Recaptcha (for spam protection)
# ===================================================================
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# ===================================================================
# Sentry (for error tracking)
# ===================================================================
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-auth-token

# ===================================================================
# Development
# ===================================================================
NODE_ENV=development
NEXT_PUBLIC_NODE_ENV=development

# ===================================================================
# Logging
# ===================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===================================================================
# Rate Limiting
# ===================================================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ===================================================================
# Content Security
# ===================================================================
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
