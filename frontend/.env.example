# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Site Configuration
NEXT_PUBLIC_SITE_NAME=CyberPress
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DESCRIPTION=A cyberpunk-themed blog platform

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=

# Feature Flags
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_SOCIAL=true
NEXT_PUBLIC_ENABLE_NEWSLETTER=true

# OAuth (Optional)
NEXT_PUBLIC_OAUTH_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_OAUTH_GITHUB_CLIENT_ID=
NEXT_PUBLIC_OAUTH_TWITTER_CLIENT_ID=

# Email (Optional)
NEXT_PUBLIC_CONTACT_EMAIL=contact@cyberpress.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@cyberpress.com

# Storage (Optional)
NEXT_PUBLIC_UPLOAD_MAX_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp
