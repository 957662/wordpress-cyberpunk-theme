# CyberPress Platform 环境变量配置

# ====================================
# WordPress API 配置
# ====================================
NEXT_PUBLIC_WP_API_URL=https://your-wordpress-site.com/wp-json
NEXT_PUBLIC_WP_USERNAME=
NEXT_PUBLIC_WP_PASSWORD=

# ====================================
# Google Analytics
# ====================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ====================================
# 站点配置
# ====================================
NEXT_PUBLIC_SITE_URL=https://cyberpress.com
NEXT_PUBLIC_SITE_NAME=CyberPress

# ====================================
# 功能开关
# ====================================
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_SEARCH=true
NEXT_PUBLIC_ENABLE_NEWSLETTER=true

# ====================================
# Cloudinary (图片上传)
# ====================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ====================================
# Disqus (评论系统)
# ====================================
NEXT_PUBLIC_DISQUS_SHORTNAME=

# ====================================
# 社交媒体链接
# ====================================
NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/yourusername
NEXT_PUBLIC_SOCIAL_TWITTER=https://twitter.com/yourusername
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/in/yourusername

# ====================================
# 联系方式
# ====================================
NEXT_PUBLIC_CONTACT_EMAIL=contact@cyberpress.com
