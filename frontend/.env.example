# CyberPress Platform - 环境变量配置模板

# ============ 站点配置 ============
NEXT_PUBLIC_SITE_NAME=CyberPress Platform
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DESCRIPTION=赛博朋克风格的现代化博客平台

# ============ WordPress API 配置 ============
NEXT_PUBLIC_WORDPRESS_API_URL=http://localhost:8080/wp-json
NEXT_PUBLIC_WORDPRESS_URL=http://localhost:8080

# ============ 认证配置 ============
NEXT_PUBLIC_JWT_SECRET=your-secret-key-here
NEXT_PUBLIC_AUTH_TOKEN_COOKIE_NAME=cyberpress_token
NEXT_PUBLIC_AUTH_REFRESH_TOKEN_COOKIE_NAME=cyberpress_refresh_token

# ============ 分析和追踪 ============
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_BAIDU_ANALYTICS_ID=

# ============ 社交媒体链接 ============
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/your-username
NEXT_PUBLIC_DISCORD_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# ============ 功能开关 ============
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_RATINGS=true
NEXT_PUBLIC_ENABLE_BOOKMARKS=true
NEXT_PUBLIC_ENABLE_SHARE=true
NEXT_PUBLIC_ENABLE_NEWSLETTER=true

# ============ 性能配置 ============
NEXT_PUBLIC_IMAGE_CDN_URL=
NEXT_PUBLIC_ASSET_CDN_URL=

# ============ 邮件配置 ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@cyberpress.dev

# ============ 数据库配置 (仅后端) ============
DB_HOST=mysql
DB_PORT=3306
DB_NAME=cyberpress
DB_USER=cyberpress
DB_PASSWORD=cyberpress_password

# ============ Redis 配置 (仅后端) ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ 其他配置 ============
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN
NEXT_PUBLIC_DEFAULT_THEME=dark
