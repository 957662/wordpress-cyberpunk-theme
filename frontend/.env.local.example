# ==================== Next.js 配置 ====================
NEXT_PUBLIC_APP_NAME=CyberPress
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================== API 配置 ====================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_V1_PREFIX=/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ==================== 分析配置 ====================
NEXT_PUBLIC_GA_ID=your-google-analytics-id
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# ==================== 功能开关 ====================
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_LIKES=true
NEXT_PUBLIC_ENABLE_BOOKMARKS=true
NEXT_PUBLIC_ENABLE_SOCIAL_SHARE=true

# ==================== 第三方服务 ====================
NEXT_PUBLIC_DISQUS_SHORTNAME=your-disqus-shortname
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=your-adsense-id

# ==================== CDN 配置 ====================
NEXT_PUBLIC_CDN_URL=https://cdn.cyberpress.dev
NEXT_PUBLIC_IMAGE_DOMAIN=images.cyberpress.dev

# ==================== OAuth 配置 ====================
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ==================== 地图配置 ====================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ==================== 支付配置 ====================
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=your-stripe-public-key

# ==================== 邮件配置 ====================
NEXT_PUBLIC_CONTACT_EMAIL=contact@cyberpress.dev
NEXT_PUBLIC_SUPPORT_EMAIL=support@cyberpress.dev

# ==================== 社交媒体 ====================
NEXT_PUBLIC_TWITTER_HANDLE=cyberpress_dev
NEXT_PUBLIC_GITHUB_URL=https://github.com/957662/wordpress-cyberpunk-theme
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/cyberpress

# ==================== SEO 配置 ====================
NEXT_PUBLIC_SITE_NAME=CyberPress
NEXT_PUBLIC_SITE_DESCRIPTION=基于 FastAPI + Next.js 的赛博朋克风格博客平台
NEXT_PUBLIC_SITE_KEYWORDS=cyberpunk,blog,next.js,fastapi,赛博朋克

# ==================== 性能配置 ====================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_TRACKING=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
