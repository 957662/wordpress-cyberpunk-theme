# CyberPress Frontend - 环境变量配置
# 复制此文件为 .env.local 并修改相应的值

# ===========================================
# API 配置
# ===========================================
# 后端 API 地址
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# 站点 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# 应用配置
# ===========================================
# 应用名称
NEXT_PUBLIC_APP_NAME=CyberPress Platform

# 应用描述
NEXT_PUBLIC_APP_DESCRIPTION=现代化赛博朋克风格博客平台

# ===========================================
# 功能开关
# ===========================================
# 启用用户注册
NEXT_PUBLIC_FEATURE_REGISTRATION=true

# 启用评论功能
NEXT_PUBLIC_FEATURE_COMMENTS=true

# 启用社交分享
NEXT_PUBLIC_FEATURE_SOCIAL_SHARING=true

# ===========================================
# 第三方服务 (可选)
# ===========================================
# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google OAuth
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# GitHub OAuth
# NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id

# ===========================================
# 上传配置
# ===========================================
# 最大上传大小 (bytes)
NEXT_PUBLIC_MAX_UPLOAD_SIZE=10485760

# 允许的文件类型
NEXT_PUBLIC_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.pdf

# ===========================================
# 分页配置
# ===========================================
# 默认每页文章数
NEXT_PUBLIC_POSTS_PER_PAGE=10

# 最大每页文章数
NEXT_PUBLIC_MAX_POSTS_PER_PAGE=50

# ===========================================
# 缓存配置
# ===========================================
# 启用客户端缓存
NEXT_PUBLIC_CACHE_ENABLED=true

# 缓存过期时间 (seconds)
NEXT_PUBLIC_CACHE_TTL=300

# ===========================================
# 开发配置
# ===========================================
# 启用调试模式
NEXT_PUBLIC_DEBUG=false

# 启用性能监控
NEXT_PUBLIC_PERFORMANCE_MONITORING=true

# ===========================================
# UI 配置
# ===========================================
# 默认主题 (light/dark/system)
NEXT_PUBLIC_DEFAULT_THEME=system

# 启用动画
NEXT_PUBLIC_ENABLE_ANIMATIONS=true

# 启用粒子效果
NEXT_PUBLIC_ENABLE_PARTICLES=true

# ===========================================
# SEO 配置
# ===========================================
# 默认 SEO 图片
NEXT_PUBLIC_DEFAULT_OG_IMAGE=/images/og-image.jpg

# 默认 Twitter 卡片类型
NEXT_PUBLIC_DEFAULT_TWITTER_CARD=summary_large_image
