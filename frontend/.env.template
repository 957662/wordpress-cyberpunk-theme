# ============================================
# CyberPress 前端环境变量配置模板
# ============================================
# 复制此文件为 .env.local 并填入实际值

# ============================================
# API 配置
# ============================================
# 后端 API 地址
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket 地址 (用于实时功能)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ============================================
# 应用配置
# ============================================
# 应用名称
NEXT_PUBLIC_APP_NAME=CyberPress

# 应用描述
NEXT_PUBLIC_APP_DESCRIPTION=赛博朋克风格博客平台

# 应用 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# 功能开关
# ============================================
# 是否启用分析
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# 是否启用错误追踪
NEXT_PUBLIC_ENABLE_SENTRY=false

# 是否启用 PWA
NEXT_PUBLIC_ENABLE_PWA=true

# 是否启用评论系统
NEXT_PUBLIC_ENABLE_COMMENTS=true

# 是否启用社交功能
NEXT_PUBLIC_ENABLE_SOCIAL=true

# ============================================
# 第三方服务配置
# ============================================

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# Disqus 评论 (可选)
# NEXT_PUBLIC_DISQUS_SHORTNAME=your-disqus-shortname

# Google OAuth
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# GitHub OAuth
# NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id

# ============================================
# 地图服务 (可选)
# ============================================
# Google Maps API Key
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# ============================================
# 支付服务 (可选)
# ============================================
# Stripe Publishable Key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# ============================================
# 内容配置
# ============================================
# 默认语言
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# 支持的语言 (逗号分隔)
NEXT_PUBLIC_LOCALES=zh-CN,en-US,ja-JP

# 时区
NEXT_PUBLIC_TIMEZONE=Asia/Shanghai

# ============================================
# 性能配置
# ============================================
# 图片优化质量 (1-100)
NEXT_PUBLIC_IMAGE_QUALITY=80

# 图片占位符
NEXT_PUBLIC_IMAGE_PLACEHOLDER=/images/placeholder.png

# ============================================
# 分页配置
# ============================================
# 默认每页数量
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=10

# 最大每页数量
NEXT_PUBLIC_MAX_PAGE_SIZE=100

# ============================================
# 缓存配置
# ============================================
# SWR 缓存时间 (毫秒)
NEXT_PUBLIC_SWR_REVALIDATE=60000

# ============================================
# UI 配置
# ============================================
# 主题模式: light, dark, system
NEXT_PUBLIC_THEME_MODE=dark

# 是否启用动画
NEXT_PUBLIC_ENABLE_ANIMATIONS=true

# ============================================
# 开发工具配置
# ============================================
# 是否显示组件名称 (React DevTools)
NEXT_PUBLIC_SHOW_REACT_DEVTOOLS=true

# 是否启用网络请求日志
NEXT_PUBLIC_ENABLE_API_LOGGING=true

# ============================================
# SEO 配置
# ============================================
# 默认 SEO 图片
NEXT_PUBLIC_DEFAULT_OG_IMAGE=/images/og-default.png

# 站点验证码
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# ============================================
# 安全配置
# ============================================
# 是否启用 CSP (Content Security Policy)
NEXT_PUBLIC_ENABLE_CSP=false

# ============================================
# 上传配置
# ============================================
# 最大上传文件大小 (MB)
NEXT_PUBLIC_MAX_UPLOAD_SIZE=10

# 允许的图片格式 (逗号分隔)
NEXT_PUBLIC_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ============================================
# 社交媒体配置
# ============================================
# Twitter 用户名
# NEXT_PUBLIC_TWITTER_USERNAME=your-twitter

# GitHub 用户名
# NEXT_PUBLIC_GITHUB_USERNAME=your-github

# LinkedIn URL
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/your-profile

# ============================================
# 生产环境注意事项
# ============================================
# 1. 更新 API_BASE_URL 为生产环境地址
# 2. 更新 APP_URL 为生产域名
# 3. 启用错误追踪 (SENTRY)
# 4. 启用分析 (GA)
# 5. 配置正确的 OAuth 密钥
# 6. 更新所有第三方服务的配置
# 7. 设置正确的 CORS 策略
# 8. 启用 HTTPS
# 9. 配置 CDN
# 10. 优化图片和静态资源
