# WordPress API Configuration
# WordPress API 配置

# WordPress Site URL (without /wp-json)
# WordPress 站点 URL（不包含 /wp-json）
NEXT_PUBLIC_WORDPRESS_URL=https://your-site.com

# WordPress REST API Endpoint (usually /wp-json)
# WordPress REST API 端点（通常是 /wp-json）
NEXT_PUBLIC_WORDPRESS_API_URL=https://your-site.com/wp-json

# WordPress API Timeout (in milliseconds)
# WordPress API 超时时间（毫秒）
NEXT_PUBLIC_WORDPRESS_API_TIMEOUT=10000

# Enable/Disable WordPress Caching
# 启用/禁用 WordPress 缓存
NEXT_PUBLIC_WORDPRESS_CACHE_ENABLED=true

# WordPress Cache Duration (in seconds)
# WordPress 缓存时长（秒）
NEXT_PUBLIC_WORDPRESS_CACHE_DURATION=300

# WordPress Posts Per Page
# WordPress 每页文章数
NEXT_PUBLIC_WORDPRESS_POSTS_PER_PAGE=12

# WordPress Featured Image Size
# WordPress 特色图片尺寸 (thumbnail, medium, large, full)
NEXT_PUBLIC_WORDPRESS_IMAGE_SIZE=large

# Enable/Disable WordPress Embedded Data
# 启用/禁用 WordPress 嵌入数据（作者、特色图片等）
NEXT_PUBLIC_WORDPRESS_EMBED_ENABLED=true

# WordPress Site Name (for SEO)
# WordPress 站点名称（用于 SEO）
NEXT_PUBLIC_SITE_NAME=CyberPress Blog

# WordPress Site Description (for SEO)
# WordPress 站点描述（用于 SEO）
NEXT_PUBLIC_SITE_DESCRIPTION=A modern cyberpunk-style blog platform

# WordPress Default Language
# WordPress 默认语言
NEXT_PUBLIC_DEFAULT_LANGUAGE=zh-CN

# WordPress Timezone
# WordPress 时区
NEXT_PUBLIC_TIMEZONE=Asia/Shanghai

# WordPress Date Format
# WordPress 日期格式
NEXT_PUBLIC_DATE_FORMAT=YYYY-MM-DD

# WordPress Time Format
# WordPress 时间格式
NEXT_PUBLIC_TIME_FORMAT=HH:mm:ss

# Enable/Disable Comments
# 启用/禁用评论
NEXT_PUBLIC_COMMENTS_ENABLED=true

# Enable/Disable Search
# 启用/禁用搜索
NEXT_PUBLIC_SEARCH_ENABLED=true

# Enable/Disable RSS Feed
# 启用/禁用 RSS 订阅
NEXT_PUBLIC_RSS_ENABLED=true

# Enable/Disable Social Sharing
# 启用/禁用社交分享
NEXT_PUBLIC_SOCIAL_SHARING_ENABLED=true

# Social Share Platforms (comma-separated)
# 社交分享平台（逗号分隔）
NEXT_PUBLIC_SOCIAL_PLATFORMS=twitter,facebook,linkedin,wechat

# Analytics Configuration
# 分析配置

# Google Analytics ID
# Google Analytics ID
NEXT_PUBLIC_GA_ID=

# Baidu Analytics ID
# 百度统计 ID
NEXT_PUBLIC_BAIDU Analytics_ID=

# Enable/Disable Reading Progress
# 启用/禁用阅读进度
NEXT_PUBLIC_READING_PROGRESS_ENABLED=true

# Enable/Disable Reading Time
# 启用/禁用阅读时间
NEXT_PUBLIC_READING_TIME_ENABLED=true

# Reading Time Words Per Minute
# 阅读时间每分钟字数
NEXT_PUBLIC_READING_TIME_WPM=200

# Enable/Disable Related Posts
# 启用/禁用相关文章
NEXT_PUBLIC_RELATED_POSTS_ENABLED=true

# Related Posts Limit
# 相关文章数量限制
NEXT_PUBLIC_RELATED_POSTS_LIMIT=4

# Enable/Disable Latest Posts Widget
# 启用/禁用最新文章小部件
NEXT_PUBLIC_LATEST_POSTS_ENABLED=true

# Latest Posts Limit
# 最新文章数量限制
NEXT_PUBLIC_LATEST_POSTS_LIMIT=5

# Enable/Disable Categories Widget
# 启用/禁用分类小部件
NEXT_PUBLIC_CATEGORIES_ENABLED=true

# Enable/Disable Tags Cloud Widget
# 启用/禁用标签云小部件
NEXT_PUBLIC_TAGS_CLOUD_ENABLED=true

# Tags Cloud Limit
# 标签云数量限制
NEXT_PUBLIC_TAGS_CLOUD_LIMIT=20

# Theme Configuration
# 主题配置

# Default Theme (light, dark, auto)
# 默认主题
NEXT_PUBLIC_DEFAULT_THEME=dark

# Accent Color
# 强调色
NEXT_PUBLIC_ACCENT_COLOR=00f0ff

# Enable/Disable PWA
# 启用/禁用 PWA
NEXT_PUBLIC_PWA_ENABLED=false

# API Configuration (if using custom backend)
# API 配置（如果使用自定义后端）

# Custom API Base URL
# 自定义 API 基础 URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# API Timeout
# API 超时时间
NEXT_PUBLIC_API_TIMEOUT=10000

# Enable/Disable API Cache
# 启用/禁用 API 缓存
NEXT_PUBLIC_API_CACHE_ENABLED=true

# API Cache Duration
# API 缓存时长
NEXT_PUBLIC_API_CACHE_DURATION=300

# Authentication Configuration
# 认证配置

# JWT Token Storage (localStorage, sessionStorage, cookie)
# JWT 令牌存储方式
NEXT_PUBLIC_TOKEN_STORAGE=localStorage

# Token Refresh Interval (in seconds)
# 令牌刷新间隔（秒）
NEXT_PUBLIC_TOKEN_REFRESH_INTERVAL=300

# Enable/Disable Remember Me
# 启用/禁用记住我
NEXT_PUBLIC_REMEMBER_ME_ENABLED=true

# Upload Configuration
# 上传配置

# Max File Size (in MB)
# 最大文件大小（MB）
NEXT_PUBLIC_MAX_FILE_SIZE=10

# Allowed Image Types (comma-separated)
# 允许的图片类型（逗号分隔）
NEXT_PUBLIC_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Image Quality (1-100)
# 图片质量（1-100）
NEXT_PUBLIC_IMAGE_QUALITY=80

# Enable/Disable Image Optimization
# 启用/禁用图片优化
NEXT_PUBLIC_IMAGE_OPTIMIZATION_ENABLED=true

# Feature Flags
# 功能开关

# Enable/Disable User Registration
# 启用/禁用用户注册
NEXT_PUBLIC_REGISTRATION_ENABLED=true

# Enable/Disable User Profiles
# 启用/禁用用户资料
NEXT_PUBLIC_USER_PROFILES_ENABLED=true

# Enable/Disable Social Login
# 启用/禁用社交登录
NEXT_PUBLIC_SOCIAL_LOGIN_ENABLED=false

# Enable/Disable Email Verification
# 启用/禁用邮箱验证
NEXT_PUBLIC_EMAIL_VERIFICATION_ENABLED=true

# Enable/Disable Two-Factor Authentication
# 启用/禁用双因素认证
NEXT_PUBLIC_2FA_ENABLED=false

# Rate Limiting
# 速率限制

# Max Requests Per Minute
# 每分钟最大请求数
NEXT_PUBLIC_RATE_LIMIT_PER_MINUTE=60

# Max Login Attempts
# 最大登录尝试次数
NEXT_PUBLIC_MAX_LOGIN_ATTEMPTS=5

# Login Lockout Duration (in seconds)
# 登录锁定时长（秒）
NEXT_PUBLIC_LOGIN_LOCKOUT_DURATION=900

# Development Mode
# 开发模式

# Enable/Disable Debug Mode
# 启用/禁用调试模式
NEXT_PUBLIC_DEBUG_MODE=false

# Enable/Disable Console Logs
# 启用/禁用控制台日志
NEXT_PUBLIC_CONSOLE_LOGS_ENABLED=true

# Enable/Disable Performance Monitoring
# 启用/禁用性能监控
NEXT_PUBLIC_PERFORMANCE_MONITORING_ENABLED=true

# Enable/Disable Error Tracking
# 启用/禁用错误追踪
NEXT_PUBLIC_ERROR_TRACKING_ENABLED=true

# External Services
# 外部服务

# Disqus Shortname (for comments)
# Disqus 短名称（用于评论）
NEXT_PUBLIC_DISQUS_SHORTNAME=

# Firebase Configuration (for notifications)
# Firebase 配置（用于通知）
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Recaptcha Site Key
# Recaptcha 站点密钥
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Cloudflare Turnstile Site Key
# Cloudflare Turnstile 站点密钥
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# CDN Configuration
# CDN 配置

# CDN Base URL
# CDN 基础 URL
NEXT_PUBLIC_CDN_URL=

# CDN Image URL
# CDN 图片 URL
NEXT_PUBLIC_CDN_IMAGE_URL=

# Enable/Disable CDN
# 启用/禁用 CDN
NEXT_PUBLIC_CDN_ENABLED=false
