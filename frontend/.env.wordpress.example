# WordPress API Configuration
# Copy this file to .env.local and configure your WordPress site

# WordPress Site URL (without trailing slash)
NEXT_PUBLIC_WORDPRESS_URL=https://your-site.com

# WordPress API Version (usually wp/v2)
NEXT_PUBLIC_WORDPRESS_API_VERSION=wp/v2

# API Request Timeout (milliseconds)
NEXT_PUBLIC_WORDPRESS_TIMEOUT=10000

# Enable Caching
NEXT_PUBLIC_WORDPRESS_ENABLE_CACHE=true

# Cache Timeout (milliseconds) - 5 minutes default
NEXT_PUBLIC_WORDPRESS_CACHE_TIMEOUT=300000

# Enable Embedding Related Data (authors, media, terms)
NEXT_PUBLIC_WORDPRESS_ENABLE_EMBED=true
