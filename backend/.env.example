# CyberPress Backend - Environment Variables

# Application
APP_NAME=CyberPress Backend
API_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://cyberpress:cyberpress@localhost:5432/cyberpress
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# WordPress
WORDPRESS_URL=http://localhost:8080
WORDPRESS_API_URL=http://localhost:8080/wp-json/wp/v2
WORDPRESS_USERNAME=
WORDPRESS_PASSWORD=
WORDPRESS_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/cyberpress.log

# Cache
CACHE_ENABLED=true
CACHE_TTL=300
