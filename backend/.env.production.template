# CyberPress Platform - 后端生产环境配置模板
# 复制此文件为 .env.production 并填写正确的值

###############################################################################
# 数据库配置
###############################################################################
POSTGRES_USER=cyberpress
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=cyberpress
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

###############################################################################
# Redis 配置
###############################################################################
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

###############################################################################
# 应用配置
###############################################################################
SECRET_KEY=your_very_secure_secret_key_change_this
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# 允许的跨域源
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# API 配置
API_V1_PREFIX=/api/v1

###############################################################################
# JWT 认证配置
###############################################################################
JWT_SECRET_KEY=your_jwt_secret_key_change_this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

###############################################################################
# 邮件配置
###############################################################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=CyberPress Platform

###############################################################################
# 文件上传配置
###############################################################################
# 最大上传大小 (MB)
MAX_UPLOAD_SIZE=10

# 允许的文件类型
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# 上传目录
UPLOAD_DIR=/app/uploads

###############################################################################
# OAuth2 配置
###############################################################################
# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

###############################################################################
# 第三方服务配置
###############################################################################
# OpenAI API (可选)
OPENAI_API_KEY=your_openai_api_key

# Sentry 错误追踪 (可选)
SENTRY_DSN=your_sentry_dsn

###############################################################################
# 监控和分析
###############################################################################
# Prometheus
ENABLE_METRICS=true
METRICS_PORT=9090

# 健康检查
HEALTH_CHECK_INTERVAL=30

###############################################################################
# 缓存配置
###############################################################################
CACHE_TTL=300
CACHE_MAX_SIZE=1000

###############################################################################
# 限流配置
###############################################################################
# API 请求限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# 认证请求限流
AUTH_RATE_LIMIT_PER_MINUTE=5

###############################################################################
# WebSocket 配置
###############################################################################
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000

###############################################################################
# 任务队列配置
###############################################################################
# 异步任务
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

###############################################################################
# 日志配置
###############################################################################
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log
LOG_ROTATION=50MB
LOG_RETENTION=30

###############################################################################
# 备份配置
###############################################################################
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_S3_BUCKET=your_backup_bucket

###############################################################################
# 安全配置
###############################################################################
# CORS
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# CSRF
CSRF_SECRET_KEY=your_csrf_secret_key

# 内容安全策略
CSP_ENABLED=true
CSP_DEFAULT_SRC=self
CSP_SCRIPT_SRC=self unsafe-inline unsafe-eval
CSP_STYLE_SRC=self unsafe-inline
CSP_IMG_SRC=self data: https:

###############################################################################
# 功能开关
###############################################################################
FEATURE_REGISTRATION=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_COMMENTS=true
FEATURE_NOTIFICATIONS=true
FEATURE_WEBSOCKET=true
FEATURE_ANALYTICS=true

###############################################################################
# 性能配置
###############################################################################
# 数据库连接池
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# 查询优化
QUERY_TIMEOUT=30
SLOW_QUERY_THRESHOLD=1.0

###############################################################################
# 国际化配置
###############################################################################
DEFAULT_LANGUAGE=zh
SUPPORTED_LANGUAGES=zh,en,ja,ko

###############################################################################
# 时间和日期
###############################################################################
TIMEZONE=Asia/Shanghai
DATE_FORMAT=%Y-%m-%d
TIME_FORMAT=%H:%M:%S
