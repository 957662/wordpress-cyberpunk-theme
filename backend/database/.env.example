# =====================================================
# CyberPress Database Configuration
# =====================================================
# 复制此文件为 .env 并填写实际值
# =====================================================

# 数据库连接
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cyberpress
DB_USER=cyberpress
DB_PASSWORD=your_secure_password_here
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# 连接池配置
DB_MIN_CONNECTIONS=2
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=60000
DB_IDLE_TIMEOUT=30000

# Redis 配置（用于缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 备份配置
BACKUP_ENABLED=true
BACKUP_DIR=/var/backups/cyberpress
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE="0 2 * * *"

# 慢查询日志
SLOW_QUERY_LOG_ENABLED=true
SLOW_QUERY_THRESHOLD=1.0

# 二进制日志
BINLOG_ENABLED=true
BINLOG_RETENTION_DAYS=7

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
